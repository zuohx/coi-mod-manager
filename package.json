{
  "name": "coi-mod-manager",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build --configLoader runner",
    "build:server": "node ./scripts/build-server.mjs",
    "format": "prettier --write package.json eslint.config.js .prettierrc.json .github/workflows/test.yml",
    "format:check": "prettier --check package.json eslint.config.js .prettierrc.json .github/workflows/test.yml",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "preview": "vite preview --configLoader runner",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --configLoader runner",
    "sync:version": "node scripts/sync-version.mjs",
    "tauri": "tauri",
    "pretauri:dev": "node scripts/sync-version.mjs",
    "tauri:dev": "tauri dev",
    "pretauri:build": "node scripts/sync-version.mjs",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "cheerio": "1.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.3.4",
    "vitest": "^3.2.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
