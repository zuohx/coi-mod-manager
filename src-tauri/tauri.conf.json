{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "COI Mod Manager",
  "version": "0.1.0",
  "identifier": "com.zuohx.coi-mod-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:server && node ./scripts/prepare-resources.mjs && pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "COI Mod Manager",
        "center": true,
        "width": 1750,
        "height": 1000,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": [
      "resources/*",
      "dist-server/*",
      "NOTICE"
    ]
  }
}
