{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "COI Mod Status Report",
  "version": "0.1.0",
  "identifier": "com.drewdon.coi-mod-status-report",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "COI Mod Status Report",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
