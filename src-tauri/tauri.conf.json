{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "COI Mod Manager",
  "version": "0.1.0",
  "identifier": "com.zuohx.coi-mod-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "COI Mod Manager",
        "center": true,
        "width": 1750,
        "height": 1000,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "http://127.0.0.1:8080/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ0MTU4MzIzMkNGOTg1MEMKUldRTWhma3NJNE1WMUdDWmFreE1mbG9jTFNUQXA3d29VVHFLcHFVcFZyYmdwNThaUFdtRzc4NnAK"
    }
  }
}
